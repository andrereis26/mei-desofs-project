# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.

APP_IMAGE=andrereis26/desofs-api:latest
APP_REPLICAS=2

POSTGRES_PORT=5432
POSTGRES_DB=desofs_db
POSTGRES_USER=desofs_user
POSTGRES_PASSWORD=

# Database connection for Spring Boot
DB_URL=jdbc:postgresql://desofs-postgres:5432/desofs_db
DB_USERNAME=desofs_user
DB_PASSWORD=

# File storage
FILE_STORAGE_PATH=./uploads
FILE_MAX_SIZE_BYTES=52428800 # 50 MB

# Rate limit Redis configuration
RATE_LIMIT_REDIS_HOST=desofs-redis-rate-limit
RATE_LIMIT_REDIS_PORT=6379
RATE_LIMIT_REDIS_PASSWORD=
RATE_LIMIT_REDIS_TIMEOUT=2s
RATE_LIMIT_REDIS_CONNECT_TIMEOUT=1s
RATE_LIMIT_REDIS_SSL=false

# Rate limit settings for authentication endpoints
AUTH_RATE_LIMIT_MAX_PER_IP=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
REGISTER_RATE_LIMIT_MAX_PER_IP=5
REGISTER_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_PER_IDENTITY=5
REGISTER_RATE_LIMIT_MAX_PER_IDENTITY=3

# Token revocation Redis configuration
TOKEN_REVOCATION_REDIS_HOST=desofs-redis-revocation
TOKEN_REVOCATION_REDIS_PORT=6379
TOKEN_REVOCATION_REDIS_PASSWORD=
TOKEN_REVOCATION_REDIS_DATABASE=1
TOKEN_REVOCATION_REDIS_TIMEOUT=2s
TOKEN_REVOCATION_REDIS_SSL=false
TOKEN_REVOCATION_REDIS_KEY_PREFIX=revoked-token:

# App configuration
JWT_SECRET=
JWT_EXPIRATION=86400000 # 24 hours in milliseconds

## Grafana configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=