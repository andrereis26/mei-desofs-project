# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.

POSTGRES_PORT=5432
POSTGRES_DB=desofs_db
POSTGRES_USER=desofs_user
POSTGRES_PASSWORD=

# Rate limit Redis configuration
RATE_LIMIT_REDIS_PORT=6379
RATE_LIMIT_REDIS_PASSWORD=

# Token revocation Redis configuration
TOKEN_REVOCATION_REDIS_PORT=6380
TOKEN_REVOCATION_REDIS_PASSWORD=

# Use a strong, randomly generated secret of at least 32 characters
JWT_SECRET=
